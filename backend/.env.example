# Backend Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="mysql://root@localhost:3306/merz_store"

# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# FRONTEND (for CORS)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Change this to a strong random string in production!
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_please
JWT_EXPIRES_IN=7d

# ============================================
# AWS S3 / MinIO (Optional - for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_bucket_name
AWS_ENDPOINT=http://localhost:9000

# ============================================
# NOTES
# ============================================
# 1. Never commit this file to git (.gitignore should exclude it)
# 2. Use different values for development and production
# 3. Keep JWT_SECRET very secure in production
# 4. Update FRONTEND_URL to your production domain when deploying
