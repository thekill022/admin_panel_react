# Frontend Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# API URL
# ============================================
# Development
VITE_API_URL=http://localhost:5000/api

# Production (uncomment and update when deploying)
# VITE_API_URL=https://your-api-domain.com/api

# ============================================
# NOTES
# ============================================
# 1. Never commit this file to git (.gitignore should exclude it)
# 2. Vite requires VITE_ prefix for environment variables
# 3. Update VITE_API_URL to your production API when deploying
# 4. Restart dev server after changing env variables
